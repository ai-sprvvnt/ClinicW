rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: 
     * This ruleset implements a robust Role-Based Access Control (RBAC) model tailored for a clinical environment. 
     * It distinguishes between global administrators and standard users (including doctors). 
     * High-level administrative tasks, such as managing rooms and doctor profiles, are restricted to users 
     * whose UIDs are explicitly present in a dedicated 'roles_admin' collection.
     * 
     * Data Structure:
     * - /users/{userId}: Private user profiles, accessible by the owner and admins.
     * - /roles_admin/{adminId}: A marker collection identifying global administrators.
     * - /rooms/{roomId}: Publicly readable clinic configuration, admin-only writes.
     * - /doctors/{doctorId}: Publicly readable medical staff registry, admin-only writes.
     * - /bookings/{bookingId}: Appointment records, readable by admins and the assigned doctor.
     * 
     * Key Security Decisions:
     * - Public Read for Directory Info: Rooms and Doctors are publicly readable to allow clinic info display.
     * - Existence over Content: Administrative status is determined by the presence of a document in /roles_admin.
     * - Denormalization for Authorization: The 'Booking' entity includes 'doctorId' directly.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isAdminOrOwner(userId) {
      return isAdmin() || isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User collection.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isAdminOrOwner(userId);
      allow list: if isAdminOrOwner(userId);
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.id == userId);
      allow update: if (isAdmin() || isOwner(userId)) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Marker collection for global admins.
     * @path /roles_admin/{adminId}
     */
    match /roles_admin/{adminId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if isAdmin(); 
    }

    /**
     * @description Clinic consulting rooms. Publicly readable to show availability.
     * @path /rooms/{roomId}
     */
    match /rooms/{roomId} {
      allow get, list: if true; // Public read allowed for clinic info
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Doctor registry. Publicly readable for directory purposes.
     * @path /doctors/{doctorId}
     */
    match /doctors/{doctorId} {
      allow get, list: if true; // Public read allowed for doctor directory
      allow create: if isAdmin();
      allow update, delete: if isAdmin() && resource != null;
    }

    /**
     * @description Appointment bookings. Secured via denormalized doctor IDs.
     * @path /bookings/{bookingId}
     */
    match /bookings/{bookingId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.doctorId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100); // Staff can list with limits
      allow create: if isAdmin(); 
      allow update: if isAdmin() && resource != null;
      allow delete: if isAdmin() && resource != null;
    }
  }
}