rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: 
     * This ruleset implements a robust Role-Based Access Control (RBAC) model.
     * It distinguishes between global administrators and standard users.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'ed.felipe.gn@gmail.com'
      );
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User collection.
     */
    match /users/{userId} {
      allow get, list: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    /**
     * @description Marker collection for global admins.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description Clinic consulting rooms. Publicly readable.
     */
    match /rooms/{roomId} {
      allow get, list: if true; 
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Doctor registry. Publicly readable.
     */
    match /doctors/{doctorId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Appointment bookings.
     * Accessible by staff (signed in) to view availability.
     * Writable by admins or the creator/doctor assigned.
     */
    match /bookings/{bookingId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && (resource.data.doctorId == request.auth.uid || resource.data.createdBy == request.auth.uid));
    }
  }
}