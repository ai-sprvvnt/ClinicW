rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: 
     * This ruleset implements a robust Role-Based Access Control (RBAC) model.
     * It distinguishes between global administrators and standard users.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'ed.felipe.gn@gmail.com'
      );
    }

    function doctorRole() {
      return get(/databases/$(database)/documents/roles_doctor/$(request.auth.uid));
    }

    function isDoctor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_doctor/$(request.auth.uid));
    }

    function clinicMatch(data) {
      // Allow legacy docs without clinicId during migration.
      return data.clinicId == null || data.clinicId == doctorRole().data.clinicId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User collection.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    /**
     * @description Marker collection for global admins.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description Marker collection for doctors.
     */
    match /roles_doctor/{doctorUid} {
      allow get: if isSignedIn() && (request.auth.uid == doctorUid || isAdmin());
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description Clinic consulting rooms. Publicly readable for availability.
     */
    match /rooms/{roomId} {
      allow get, list: if isAdmin() || (isDoctor() && clinicMatch(resource.data)); 
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Doctor registry. Publicly readable for identification.
     */
    match /doctors/{doctorId} {
      allow get, list: if isAdmin() || (isDoctor() && clinicMatch(resource.data));
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Appointment bookings.
     * Publicly readable so everyone can see if a room is occupied.
     * Writable only by staff/admins.
     */
    match /bookings/{bookingId} {
      allow get, list: if isAdmin() || (
        isDoctor() &&
        clinicMatch(resource.data) &&
        (doctorRole().data.canViewAllBookings == true || resource.data.doctorId == doctorRole().data.doctorId)
      );
      // Writes must go through server (Functions).
      allow create, update, delete: if isAdmin();
    }
  }
}
