rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Core Philosophy: 
     * This ruleset implements a robust Role-Based Access Control (RBAC) model.
     * It distinguishes between global administrators and standard users.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email == 'ed.felipe.gn@gmail.com'
      );
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User collection.
     */
    match /users/{userId} {
      allow get, list: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    /**
     * @description Marker collection for global admins.
     * A user can always check their own status.
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list, create, update, delete: if isAdmin();
    }

    /**
     * @description Clinic consulting rooms. Publicly readable for the dashboard.
     */
    match /rooms/{roomId} {
      allow get, list: if true; 
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Doctor registry. Publicly readable for the directory.
     */
    match /doctors/{doctorId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Appointment bookings.
     */
    match /bookings/{bookingId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.doctorId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100);
      allow create, update, delete: if isAdmin();
    }
  }
}